# OpenAPI-specific test runner base image (PHP 8.2)
FROM php:8.2-cli-bookworm

LABEL maintainer="PlanHub Development Team"
LABEL description="Testing base image for PlanHub OpenAPI (PHP 8.2)"
LABEL version="1.0"

WORKDIR /app

ARG DUCKDB_VERSION=1.5.1
ARG TARGETARCH

RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
        git \
        curl \
        libcurl4-openssl-dev \
        libpng-dev \
        libxml2-dev \
        zip \
        unzip \
        libonig-dev \
        libzip-dev \
        libfreetype6-dev \
        libjpeg62-turbo-dev \
        libwebp-dev \
        libicu-dev \
        autoconf \
        g++ \
        make \
        libssl-dev \
        linux-libc-dev \
        bash \
        default-mysql-client \
        sqlite3 \
        libsqlite3-dev \
        jq \
        graphviz \
        fonts-dejavu-core \
        ca-certificates; \
    rm -rf /var/lib/apt/lists/*

RUN set -eux; \
    case "${TARGETARCH}" in \
      amd64) DUCK_ARCH="amd64" ;; \
      arm64) DUCK_ARCH="arm64" ;; \
      *) echo "Unsupported TARGETARCH=${TARGETARCH} for DuckDB"; exit 1 ;; \
    esac; \
    curl -fsSL "https://install.duckdb.org/v${DUCKDB_VERSION}/duckdb_cli-linux-${DUCK_ARCH}.zip" -o /tmp/duckdb.zip; \
    unzip -q /tmp/duckdb.zip -d /usr/local/bin; \
    chmod +x /usr/local/bin/duckdb; \
    rm -f /tmp/duckdb.zip; \
    duckdb -version

RUN docker-php-ext-configure gd --with-freetype --with-jpeg --with-webp \
    && docker-php-ext-install \
        -j"$(nproc)" \
        pdo_mysql \
        pdo_sqlite \
        mbstring \
        exif \
        pcntl \
        bcmath \
        gd \
        zip \
        intl \
        soap \
        opcache \
        sockets

RUN set -eux; \
    pecl install mongodb-1.21.0 redis pcov; \
    docker-php-ext-enable mongodb redis pcov

COPY --from=composer:2.3 /usr/bin/composer /usr/bin/composer
ENV COMPOSER_HOME=/usr/local/composer

RUN COMPOSER_HOME=/usr/local/composer composer global require \
        phpunit/phpunit:^10.0 \
        squizlabs/php_codesniffer:^3.11 \
    && COMPOSER_HOME=/usr/local/composer composer global clear-cache

ENV PATH="/usr/local/composer/vendor/bin:${PATH}"

COPY scripts/ph-test-runner /usr/local/bin/ph-test-runner
RUN chmod +x /usr/local/bin/ph-test-runner

RUN echo "memory_limit=4G" >> /usr/local/etc/php/conf.d/testing.ini \
    && echo "max_execution_time=300" >> /usr/local/etc/php/conf.d/testing.ini \
    && echo "display_errors=On" >> /usr/local/etc/php/conf.d/testing.ini \
    && echo "log_errors=On" >> /usr/local/etc/php/conf.d/testing.ini \
    && echo "pcov.directory=/app" >> /usr/local/etc/php/conf.d/testing.ini \
    && echo "pcov.exclude=\"#(vendor|tests|storage|bootstrap/cache)#\"" >> /usr/local/etc/php/conf.d/testing.ini

RUN groupadd -g 1000 planhub \
    && useradd -u 1000 -g planhub -m -s /bin/bash planhub

RUN mkdir -p /app/storage/logs \
             /app/storage/framework/cache \
             /app/storage/framework/sessions \
             /app/storage/framework/views \
             /app/bootstrap/cache \
    && chown -R planhub:planhub /app

USER planhub
WORKDIR /app

ENV APP_ENV=testing
ENV DB_CONNECTION=sqlite
ENV DB_DATABASE=:memory:
ENV CACHE_DRIVER=array
ENV SESSION_DRIVER=array
ENV QUEUE_CONNECTION=sync
ENV MAIL_MAILER=array

CMD ["bash", "-c", "echo '🧪 PlanHub OpenAPI Testing Base Image (PHP 8.2)' && php -v | head -1 && composer --version && phpunit --version && phpcs --version && duckdb -version && echo '✅ Ready'"]
